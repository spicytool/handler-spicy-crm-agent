# === LOCAL DEVELOPMENT ONLY ===
# In production (Cloud Run), these are set via gcloud run deploy --set-env-vars.
# This file is gitignored and should never be committed.

# Google Cloud / Vertex AI Configuration
# Required: Google Cloud Project ID
# GOOGLE_CLOUD_PROJECT=spicy-inbound-handler

# Optional: Google Cloud Location (default: us-central1)
# GOOGLE_CLOUD_LOCATION=us-central1

# Required: Agent Engine ID for the CRM agent (no hardcoded fallback)
# Can be full resource name or bare ID
# AGENT_ENGINE_ID=projects/383441555516/locations/us-central1/reasoningEngines/<YOUR_ENGINE_ID>

# Debug: enable deep session/event logging
# DEBUG_AGENT_SESSIONS=1
